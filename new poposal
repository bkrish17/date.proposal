<!DOCTYPE html>
<html>
<head>
<title>Date Proposal</title>

<style>
body{
    text-align:center;
    font-family: Arial;
    background: linear-gradient(pink, white);
    height:100vh;
}

h1{
    margin-top:100px;
    color:#d63384;
    font-size:40px;
}

button{
    padding:15px 30px;
    font-size:20px;
    border:none;
    border-radius:10px;
    cursor:pointer;
    margin:20px;
}

#yes{
    background-color:#ff4d6d;
    color:white;
}

#no{
    background-color:#444;
    color:white;
    position:absolute;
}

#result{
    font-size:35px;
    color:green;
    margin-top:40px;
}
</style>

<script>

function moveButton(){
    var button = document.getElementById("no");

    var x = Math.random() * (window.innerWidth - 100);
    var y = Math.random() * (window.innerHeight - 100);

    button.style.left = x + "px";
    button.style.top = y + "px";
}

function sayYes(){
    document.getElementById("result").innerHTML =
    "Yayyy ❤️ I knew you would say YES! Let's go on a date!";
}

</script>
</head>

<body>

<h1>💖 Would you like to go on a date with me? 💖</h1>

<button id="yes" onclick="sayYes()">Yes 💕</button>
<button id="no" onmouseover="moveButton()">No 😅</button>

<div id="result"></div>

</body>
</html>